PORT=3888
JWT_SECRET=замените_на_длинную_случайную_строку
# Первый администратор создаётся при первом запуске, если БД пуста:
INITIAL_ADMIN_EMAIL=admin@autosim.local
INITIAL_ADMIN_PASSWORD=измените_пароль
# Если INITIAL_ADMIN_PASSWORD задан (не пустой), при каждом запуске пароль
# этого админа в SQLite обновляется под значение из окружения (удобно на Railway).

# Не создавать демо employee@autosim.local / customer@autosim.local (по умолчанию создаются):
# AUTOSIM_SKIP_DEMO_USERS=1

# Не добавлять однократный набор данных для админ-панели (брони, сессии, уведомления):
# AUTOSIM_SKIP_ADMIN_DEMO=1
